# Database (required)
DATABASE_URL=postgresql://lwc:lwc_dev@localhost:5432/kaibase

# Redis (BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=dev-secret-change-me-in-production

# AI Providers (OPENAI_API_KEY required for AI workers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Optional: override default AI models
# CLASSIFY_MODEL=gpt-5.4-mini
# EXTRACT_ENTITIES_MODEL=gpt-5.4-mini
# SUMMARIZE_MODEL=gpt-5.4
# PAGE_CREATE_MODEL=gpt-5.4
# QA_MODEL=gpt-5.4

# Optional: reasoning effort overrides for GPT-5.x / reasoning-capable models
# CLASSIFY_REASONING=low
# EXTRACT_ENTITIES_REASONING=low
# SUMMARIZE_REASONING=medium
# PAGE_CREATE_REASONING=medium
# QA_REASONING=medium

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=lwc_minio
MINIO_SECRET_KEY=lwc_minio_dev
MINIO_BUCKET=kaibase-sources

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
