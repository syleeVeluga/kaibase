# Database (required)
DATABASE_URL=postgresql://lwc:lwc_dev@localhost:5432/kaibase

# Redis (BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=dev-secret-change-me-in-production

# AI Providers (OPENAI_API_KEY required for AI workers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Optional: override default AI models
# CLASSIFY_MODEL=gpt-4o-mini
# EXTRACT_ENTITIES_MODEL=gpt-4o-mini
# PAGE_CREATE_MODEL=gpt-4o

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=lwc_minio
MINIO_SECRET_KEY=lwc_minio_dev
MINIO_BUCKET=kaibase-sources

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Workspace defaults
# WORKSPACE_LANGUAGE=en
