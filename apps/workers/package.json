{
  "name": "@kaibase/workers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@kaibase/ai": "workspace:*",
    "@kaibase/connectors": "workspace:*",
    "@kaibase/db": "workspace:*",
    "@kaibase/policy": "workspace:*",
    "@kaibase/shared": "workspace:*",
    "bullmq": "5.69.3",
    "ioredis": "^5.6.1",
    "pino": "^9.8.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.2",
    "vitest": "4.0.5"
  }
}
