{
  "name": "@kaibase/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.6",
    "@kaibase/db": "workspace:*",
    "@kaibase/policy": "workspace:*",
    "@kaibase/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "bullmq": "5.69.3",
    "hono": "4.12.2",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "pino": "^9.8.0",
    "pino-pretty": "^13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "6.0.2",
    "vitest": "4.0.5"
  }
